#!/usr/bin/env python3
"""List SteamVR tracked devices and their serial numbers."""

from __future__ import annotations

import argparse
import json
import sys

from vive_openvr.openvr_tracker_wrapper import OpenVRTrackerWrapper, require_openvr


def _list_devices(include_all: bool) -> list[dict]:
    require_openvr()
    wrapper = OpenVRTrackerWrapper(tracker_serials={}, apply_role_corrections=False)
    try:
        statuses = wrapper.device_statuses()
        return [
            {
                "index": device.index,
                "class": device.device_class_name,
                "serial": device.serial,
                "status": {
                    "connected": statuses[device.index].connected,
                    "pose_valid": statuses[device.index].pose_valid,
                    "tracking_result": statuses[device.index].tracking_result,
                    "tracking_result_name": statuses[device.index].tracking_result_name,
                    "position": statuses[device.index].position,
                },
            }
            for device in wrapper.list_devices(include_all=include_all)
        ]
    finally:
        wrapper.shutdown()


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="List OpenVR tracked devices")
    parser.add_argument(
        "--all",
        action="store_true",
        help="include HMD, controllers, and base stations; default only lists trackers",
    )
    parser.add_argument("--json", action="store_true", help="print JSON output")
    args = parser.parse_args(argv)

    try:
        devices = _list_devices(include_all=args.all)
    except RuntimeError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    except Exception as exc:
        print(f"ERROR: failed to query OpenVR devices: {exc}", file=sys.stderr)
        return 1

    if args.json:
        print(json.dumps(devices, indent=2, ensure_ascii=False))
        return 0

    if not devices:
        print("No OpenVR trackers found.")
        return 0

    for device in devices:
        status = device["status"]
        position = status["position"]
        if position is None:
            xyz = "xyz=n/a"
        else:
            xyz = "xyz=[{:.3f}, {:.3f}, {:.3f}]".format(*position)
        print(
            "index={index:<2} class={class:<17} serial={serial} "
            "connected={connected:<5} valid={pose_valid:<5} result={result:<3} {result_name} {xyz}".format(
                index=device["index"],
                **{
                    "class": device["class"],
                    "serial": device["serial"],
                    "connected": str(status["connected"]),
                    "pose_valid": str(status["pose_valid"]),
                    "result": status["tracking_result"],
                    "result_name": status["tracking_result_name"],
                    "xyz": xyz,
                },
            )
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
